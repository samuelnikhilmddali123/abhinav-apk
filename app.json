{
  "expo": {
    "name": "jewelry-expo",
    "slug": "jewelry-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.webp",
    "scheme": "jewelryexpo",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo.webp",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo.webp"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.webp"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
