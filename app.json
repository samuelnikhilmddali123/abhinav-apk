{
  "expo": {
    "name": "Abhinav Gold and Silver",
    "slug": "abhinav-gold-and-silver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Untitled design (2).png",
    "scheme": "jewelryexpo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.nikhil_2003.jewelryexpo"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
